<Window x:Class="LinearListDemo.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Демонстрация класса Линейный_список"
        Width="860"
        Height="560"
        MinWidth="760"
        MinHeight="500"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="24"
                   FontWeight="SemiBold"
                   Text="Класс «Линейный_список»" />

        <Border Grid.Row="1"
                Margin="0,16,0,16"
                Padding="14"
                BorderBrush="#C7CED9"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock FontSize="14"
                           FontWeight="Medium"
                           Text="Добавление нового элемента" />
                <DockPanel Margin="0,8,0,0">
                    <Button Width="130"
                            Height="34"
                            HorizontalAlignment="Right"
                            Command="{Binding AddCommand}"
                            Content="Добавить" />
                    <TextBox Margin="0,0,10,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding NewElement, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>
                <WrapPanel Margin="0,12,0,0">
                    <Button Width="180"
                            Height="34"
                            Margin="0,0,10,0"
                            Command="{Binding RemoveCurrentCommand}"
                            Content="Удалить текущий" />
                    <Button Width="180"
                            Height="34"
                            Margin="0,0,10,0"
                            Command="{Binding MoveNextCommand}"
                            Content="Следующий элемент" />
                    <Button Width="180"
                            Height="34"
                            Command="{Binding MoveToStartCommand}"
                            Content="Перейти в начало" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="12"
                    BorderBrush="#C7CED9"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Text="Элементы списка" />
                    <ListBox Margin="0,8,0,0"
                             IsHitTestVisible="False"
                             ItemsSource="{Binding Elements}"
                             SelectedIndex="{Binding CurrentIndex, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Padding="12"
                    BorderBrush="#C7CED9"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Text="Состояние списка" />
                    <TextBlock Margin="0,12,0,0"
                               Text="{Binding CurrentElementText, StringFormat=Текущий элемент: {0}}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding CurrentPositionText, StringFormat=Позиция: {0}}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding Count, StringFormat=Количество элементов: {0}}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding IsEmpty, StringFormat=Список пуст: {0}}" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Margin="0,16,0,0"
                Padding="12"
                Background="#F5F8FF"
                BorderBrush="#CBD7F0"
                BorderThickness="1"
                CornerRadius="8">
            <TextBlock Text="{Binding StatusMessage}" />
        </Border>
    </Grid>
</Window>
